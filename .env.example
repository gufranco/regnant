# Copy to .env and adjust as needed.
# Never commit .env. Secrets here are local-dev only.

# LocalStack region label echoed into AWS_DEFAULT_REGION.
REGION_LABEL=us-east-1

# Keycloak bootstrap admin (local dev only).
KEYCLOAK_ADMIN_PASSWORD=changeme

# Grafana admin (local dev only).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# OSB broker basic-auth (local dev only).
OSB_BROKER_USERNAME=broker
OSB_BROKER_PASSWORD=changeme

# Number of Envoy instances. Compose defines 3 explicitly; Terraform
# scales the catalog. Increase together if you want more.
ENVOY_INSTANCE_COUNT=3
