{
  "title": "Sovereign XDS Latency",
  "uid": "regnant-sovereign",
  "tags": ["regnant", "sovereign", "xds"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "type": "stat",
      "title": "Connected nodes",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sovereign_connected_nodes", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "XDS push latency p95",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sovereign_xds_push_seconds_bucket[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Discovery requests by type",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (xds_type) (rate(sovereign_discovery_requests_total[5m]))",
          "legendFormat": "{{xds_type}}",
          "refId": "A"
        }
      ]
    }
  ]
}
