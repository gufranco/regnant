{
  "title": "OSB Throughput and Latency",
  "uid": "regnant-osb",
  "tags": ["regnant", "osb"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "type": "stat",
      "title": "Provision queue depth",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "aws_sqs_approximate_number_of_messages_visible{queue_name=\"regnant-provision-tasks\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Binding queue depth",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "aws_sqs_approximate_number_of_messages_visible{queue_name=\"regnant-binding-tasks\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP requests by status",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total{job=\"osb-api\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Worker op duration p95",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (op, le) (rate(osb_worker_op_seconds_bucket[5m])))",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    }
  ]
}
