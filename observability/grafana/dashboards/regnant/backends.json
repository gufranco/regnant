{
  "title": "Backend Comparison (Jira/Confluence/Bitbucket clones)",
  "uid": "regnant-backends",
  "tags": ["regnant", "backends"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "RPS per backend",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(http_requests_total{service_name=~\"backend-.*-clone\"}[5m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p95 per backend",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (service_name, le) (rate(http_request_duration_seconds_bucket{service_name=~\"backend-.*-clone\"}[5m])))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Error rate per backend",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(http_requests_total{service_name=~\"backend-.*-clone\",status=~\"5..\"}[5m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ]
    }
  ]
}
